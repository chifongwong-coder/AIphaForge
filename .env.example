# ==============================================================
# AIphaForge Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
# ==============================================================

# ----- Data Source (optional, for external data fetching scripts) -----
# DATA_PROVIDER=yahoo
# ALPHA_VANTAGE_API_KEY=your_key_here
# TUSHARE_TOKEN=your_token_here

# ----- AI Agent (optional, for agent integration via hooks) -----
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# AGENT_MODEL=gpt-4o
# AGENT_TIMEOUT=120

# ----- Logging -----
# LOG_LEVEL=INFO
# LOG_FILE=backtest.log

# ----- Database (optional, for storing backtest results) -----
# DATABASE_URL=sqlite:///results.db
